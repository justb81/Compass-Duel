<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ── Nearby Connections (offline P2P: BLE-only, low power) ─────────── -->
    <!-- Bluetooth (API 31+). minSdk is 35, so the legacy BLUETOOTH/
         BLUETOOTH_ADMIN and ACCESS_*_LOCATION permissions are not needed —
         neverForLocation declares we don't derive physical location.
         Nearby is pinned to low power (BLE only) in NearbyConnectionManager so it
         never negotiates the Wi-Fi/Bluetooth-Classic bandwidth upgrade — that
         upgrade raises an OS Bluetooth pairing dialog on join. Because the Wi-Fi
         medium is therefore unused, the ACCESS_WIFI_STATE / CHANGE_WIFI_STATE /
         NEARBY_WIFI_DEVICES permissions are intentionally not declared. -->
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />

    <!-- Haptic feedback (hit / incoming attack / shield). -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Step detection: flags a player who physically leaves their seat mid-round.
         Optional — the app degrades to significant-motion-only when not granted. -->
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />

    <!-- BLE is the primary discovery channel. -->
    <uses-feature android:name="android.hardware.bluetooth_le" android:required="true" />

    <!-- Touchscreen not strictly required (orientation/tilt is the core input). -->
    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />

    <application
        android:name=".CompassDuelApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CompassDuel">

        <!-- Portrait lock is a deliberate gameplay choice: the phone is held
             upright like a wand/compass and the targeting ring is designed for
             a portrait viewport. Android 16 ignores fixed orientation on large
             screens; that is acceptable here (the game is a phone-held
             experience), so the DiscouragedApi/LockedOrientationActivity lint
             warnings are suppressed intentionally. -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.CompassDuel"
            tools:ignore="DiscouragedApi,LockedOrientationActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
