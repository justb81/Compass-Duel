<?xml version="1.0" encoding="utf-8"?>
<!--
    Backup rules for Android 11 and lower (API ≤ 30), where
    android:dataExtractionRules does not yet apply. Mirrors
    android:allowBackup="false": Compass Duel keeps no durable user data worth
    backing up — game sessions are ephemeral and fully local.
-->
<full-backup-content>
    <exclude domain="root" />
    <exclude domain="file" />
    <exclude domain="database" />
    <exclude domain="sharedpref" />
    <exclude domain="external" />
</full-backup-content>
